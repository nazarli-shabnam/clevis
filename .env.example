# Postgres credentials — used by Docker Compose (db service) and to construct DATABASE_URL
DB_USER=
DB_PASSWORD=
DB_NAME=

# Full connection URL for local dev (apps/api, apps/worker running outside Docker).
# Docker Compose constructs its own URL from the DB_* vars above using the internal hostname "db".
DATABASE_URL=

# Secret key for job token encryption — generate with: openssl rand -hex 32
JOB_SECRET_KEY=

# GitHub API
GITHUB_API_BASE=https://api.github.com

# API server
API_PORT=8080
CORS_ORIGINS=["http://localhost:3000"]
DEFAULT_RBAC_ROLE=viewer
DEBUG=false

# Worker
WORKER_POLL_SECONDS=5

# UI
UI_PORT=3000
NEXT_PUBLIC_API_BASE=http://localhost:8080
# Role used for privileged API calls (e.g. cache clear). The X-Role header is trusted by the
# API — only set this to "admin" on deployments where the UI sits behind an auth proxy that
# restricts access appropriately. Default is "viewer" (cache clear will be rejected by the API).
NEXT_PUBLIC_DEFAULT_ROLE=viewer
