# API and worker build contexts are repo root — keep the daemon upload small and safe.

.git
.gitignore

# Secrets (never bake into images)
.env
.env.*
!.env.example

# Local runtime data
data/

# Python noise
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/

# JS/Next (other apps; not used by API Dockerfile)
**/node_modules/
**/.next/
**/out/
**/.turbo/
**/*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Agent / editor metadata (not needed in API image)
.agents/
.github/

# Images that COPY only apps/api (worker Dockerfile also uses repo root context)
apps/ui/
deploy/

# Local reference tree if present
prowler/

# Editor / IDE
.idea/
.vscode/
.cursor/
